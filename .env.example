# ── 必填项 ──────────────────────────────────────────────────
# 生成命令：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-at-least-32-characters!!
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=app
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=Admin1234

# ── 可选项（已有默认值）────────────────────────────────────
# ENVIRONMENT=development          # development | staging | production | test
# POSTGRES_PORT=5432
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_MINUTES=10080
# 无密码（默认）：REDIS_URL=redis://localhost:6379/0
# 带密码：       REDIS_URL=redis://:yourpassword@localhost:6379/0
# 带用户名+密码： REDIS_URL=redis://username:yourpassword@localhost:6379/0
# REDIS_URL=redis://localhost:6379/0
# TRUSTED_HOSTS=127.0.0.1
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# FIRST_SUPERUSER_FULL_NAME=Admin User
# PROJECT_NAME=FastAPI Backend
# API_V1_STR=/api/v1
